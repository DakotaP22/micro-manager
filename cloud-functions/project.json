{
  "name": "cloud-functions",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "cloud-functions/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/cloud-functions",
        "main": "cloud-functions/src/index.js",
        "tsConfig": "cloud-functions/tsconfig.lib.json",
        "assets": ["cloud-functions/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "cloud-functions/**/*.js",
          "cloud-functions/package.json"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "cloud-functions/jest.config.js",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    }
  },
  "tags": []
}
